# Server
PORT=5000
NODE_ENV=development

# MySQL fallback (used when DATABASE_URL is missing or has placeholder password)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cleaning_platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (must match Supabase Site URL and redirect URLs)
FRONTEND_URL=http://localhost:3000

# Supabase Postgres (backend uses this when password is set)
DATABASE_URL=postgresql://postgres.qcqxhhndmlnzwnzekfex:[YOUR-PASSWORD]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# Supabase Auth (verification + password reset emails)
USE_SUPABASE_EMAIL=true
SUPABASE_URL=https://qcqxhhndmlnzwnzekfex.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# SMTP (optional - for custom HTML emails; Supabase magic link used as fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=Mycleaning <noreply@cleaningplatform.com>

# Super Admin notifications (email/SMS when tenants register or need approval)
SUPER_ADMIN_NOTIFY_EMAIL=admincleaning43@gmail.com
SUPER_ADMIN_NOTIFY_PHONE=+237XXXXXXXXX

# SMS via Twilio (optional - logs to console in dev if not configured)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Flutterwave (v4 OAuth - test/sandbox)
FLW_ENV=test
FLW_CLIENT_ID=your-flutterwave-client-id
FLW_CLIENT_SECRET=your-flutterwave-client-secret
FLW_ENCRYPTION_KEY="your-flutterwave-encryption-key"
FLW_WEBHOOK_HASH=your-webhook-secret-hash-at-least-36-chars
# Must be HTTPS if set (Flutterwave rejects localhost redirect URLs)
FLW_REDIRECT_BASE=
FLW_REDIRECT_VIA_BACKEND=false
